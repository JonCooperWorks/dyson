{
  "config_version": 2,
  "providers": {
    "default": {
      "type": "openai",
      "models": ["llama-3.2-3b-instruct"],
      "api_key": "not-needed",
      "base_url": "http://localhost:9000"
    }
  },
  "agent": {
    "provider": "default",
    "max_iterations": 20,
    "max_tokens": 8192
  },
  "controllers": [
    {
      "type": "telegram",
      "bot_token": {
        "resolver": "insecure_env",
        "name": "TELEGRAM_API_KEY"
      },
      "allowed_chat_ids": [
        {
          "resolver": "insecure_env",
          "name": "TELEGRAM_ALLOWED_CHAT_ID"
        }
      ]
    }
  ],
  "skills": {
    "builtin": {
      "tools": []
    }
  }
}
