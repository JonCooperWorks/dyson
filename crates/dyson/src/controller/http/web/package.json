{
  "name": "dyson-web",
  "version": "0.1.0",
  "private": true,
  "description": "Web UI for the dyson HTTP controller. Bundled into the Rust binary by crates/dyson/build.rs.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "vitest run && vite build",
    "build:nocheck": "vite build",
